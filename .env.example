# --- Copy this file to ".env" and fill in your values ---
# (the agent reads these as environment variables)

# football-data.org free API token — get one at https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=your_token_here

# Slack incoming webhook URL — see SETUP.md step 3
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# OPTIONAL: enables the one-line AI context per game. Omit to skip it.
ANTHROPIC_API_KEY=
